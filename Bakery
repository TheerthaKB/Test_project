<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sweet Delight Bakery</title>

    <style>
        *{
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body{
            font-family: Arial, sans-serif;
            background-image: url('bakeryyy.jpg');
            background-size: cover;
            background-position: center;
            background-attachment: fixed;
            color: #222;
        }

        .container{
            width: 85%;
            margin: auto;
        }

        .card{
            margin: 40px 0;
            padding: 30px;
            border-radius: 15px;
            background-color: rgba(255,255,255,0.9);
            box-shadow: 0 4px 10px rgba(0,0,0,0.3);
        }

        h1{
            text-align: center;
            font-size: 50px;
            color: #8b0000;
            margin-bottom: 10px;
        }

        .tagline{
            text-align: center;
            font-style: italic;
            margin-bottom: 20px;
        }

        .btn{
            display: inline-block;
            padding: 12px 20px;
            background-color: #ffb703;
            color: black;
            text-decoration: none;
            font-weight: bold;
            border-radius: 8px;
            transition: 0.3s;
        }

        .btn:hover{
            background-color: #fb8500;
            color: white;
        }

        nav ul{
            list-style: none;
            display: flex;
            gap: 20px;
            margin-top: 15px;
        }

        nav a{
            text-decoration: none;
            color: #8b0000;
            font-weight: bold;
        }

        nav a:hover{
            color: #fb8500;
        }

        .products{
            display: flex;
            gap: 40px;
            flex-wrap: wrap;
            margin-top: 20px;
        }

        .item{
            text-align: center;
            background-color: #fff5e6;
            padding: 20px;
            border-radius: 10px;
            width: 220px;
        }

        .item img{
            width: 180px;
            height: 180px;
            object-fit: cover;
            border-radius: 10px;
        }

        .item h3{
            margin-top: 15px;
            color: #8b0000;
        }

        .item p{
            margin-top: 8px;
        }

        footer{
            margin-top: 30px;
            text-align: center;
        }

        footer a{
            margin: 0 10px;
            text-decoration: none;
            color: #8b0000;
            font-weight: bold;
        }

        footer a:hover{
            color: #fb8500;
        }
    </style>
</head>

<body>

    <div class="container">

        <!-- HERO SECTION -->
        <div class="card">
            <h1>Sweet Delight Bakery</h1>

            <p class="tagline">
                Freshly baked happiness every day 🍰
            </p>

            <center>
                <a class="btn" href="#">Explore Our Menu</a>
            </center>
        </div>

        <!-- NAVIGATION -->
        <div class="card">
            <h2>Navigation</h2>

            <nav>
                <ul>
                    <li><a href="#">Home</a></li>
                    <li><a href="#">Menu</a></li>
                    <li><a href="#">About</a></li>
                    <li><a href="#">Contact</a></li>
                </ul>
            </nav>
        </div>

        <!-- TOP SELLERS -->
        <div class="card">
            <h2>Top Sellers</h2>

            <div class="products">

                <div class="item">
                    <img src="cake.png" alt="Red Velvet Cake">

                    <h3>Red Velvet Cake</h3>

                    <p>Rich, creamy and delicious.</p>
                </div>

                <div class="item">
                    <img src="brownie.png" alt="Brownie">

                    <h3>Chocolate Brownie</h3>

                    <p>Soft, fudgy and chocolaty.</p>
                </div>

            </div>

            <footer>
                <a href="#">Facebook</a>
                <a href="#">Instagram</a>
                <a href="#">Twitter</a>
            </footer>
        </div>

    </div>

</body>
</html>
